# ---- Server ----
NODE_ENV=development
PORT=4002
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eams?schema=public"

# ---- Auth (JWT) ----
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ---- SSO (Microsoft Entra ID) — optional placeholders ----
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
